<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="240.0" prefWidth="440.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sau.schoolmanagement1.controller.EnrollmentsController">

    <children>

        <Label layoutX="26.0" layoutY="20.0" text="STUDENT ID:" />
        <Label layoutX="26.0" layoutY="50.0" text="COURSE ID:" />
        <Label layoutX="26.0" layoutY="81.0" text="CLASS DATE:" />
        <Label layoutX="26.0" layoutY="111.0" text="TUITION:" />
        <Label layoutX="26.0" layoutY="141.0" text="ATTENDANCE:" />

        <TextField fx:id="studentId" layoutX="130.0" layoutY="16.0" />
        <TextField fx:id="courseId" layoutX="130.0" layoutY="46.0" />
        <DatePicker fx:id="classDate" layoutX="130.0" layoutY="76.0" />
        <TextField fx:id="tuition" layoutX="130.0" layoutY="106.0" />
        <TextField fx:id="attendance" layoutX="130.0" layoutY="136.0" />

        <Button fx:id="saveEnrollment" layoutX="30.0" layoutY="185.0" mnemonicParsing="false" onAction="#saveEnrollment" text="ENROLL" />

        <Button fx:id="updateEnrollment" layoutX="115.0" layoutY="185.0" mnemonicParsing="false" onAction="#updateEnrollment" text="UPDATE" />

        <Button fx:id="deleteEnrollment" layoutX="205.0" layoutY="185.0" mnemonicParsing="false" onAction="#deleteEnrollment" text="DELETE" />

        <Button fx:id="clearEnrollment" layoutX="306.0" layoutY="137.0" mnemonicParsing="false" onAction="#clearEnrollment" text="CLEAR" />

        <Button fx:id="close" layoutX="280.0" layoutY="185.0" mnemonicParsing="false" onAction="#close" text="CLOSE" />

        <Button fx:id="getEnrollment" layoutX="308.0" layoutY="16.0" mnemonicParsing="false" onAction="#getEnrollment" prefHeight="24.0" prefWidth="56.0" text="GET" />
    </children>
</AnchorPane>
